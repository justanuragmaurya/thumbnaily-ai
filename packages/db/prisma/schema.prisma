// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  credits      Int            @default(5)
  name         String
  avatar       String?        
  password     String?        
  updatedAt    DateTime       @updatedAt
  thumbnails   Thumbnails[]
  generationJobs GenerationJob[]
}

model Thumbnails{
  id String @id @default(cuid())
  prompt String
  link String
  isPublic Boolean @default(true)
  createdAt DateTime @default(now())
  creatorID String
  creator User @relation(fields: [creatorID], references: [id])
  referenceImages ThumbnailReferenceImage[]

  @@index([creatorID, createdAt(sort: Desc)])
  @@index([isPublic, createdAt(sort: Desc)])
}


model ThumbnailReferenceImage {
  id          String     @id @default(cuid())
  url         String
  thumbnailId String
  thumbnail   Thumbnails @relation(fields: [thumbnailId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([thumbnailId])
}

model WaitlistUsers{
  id String @id @default(cuid())
  email String @unique
  createdAt DateTime @default(now())
}

model GenerationJob {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String
  basicPrompt    String
  enhancedPrompt String?
  imageUrls      String[]  @default([])
  isPublic       Boolean   @default(true)
  errorMessage   String?
  progress       Int       @default(0)
  resultUrl      String?
  thumbnailId    String?
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model WebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  providerEventId String
  type            String
  status          String
  payload         Json
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([provider, providerEventId])
  @@index([status, createdAt(sort: Desc)])
}